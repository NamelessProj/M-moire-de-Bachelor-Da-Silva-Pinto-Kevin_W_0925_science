    title = {Utilisation des web workers - {Les} {API} {Web} {\textbar} {MDN}},
    url = {https://developer.mozilla.org/fr/docs/Web/API/Web_Workers_API/Using_web_workers},
    abstract = {Les Web Workers sont un outil permettant au contenu web d'exécuter des scripts dans des tâches (threads) d'arrière-plan. Le thread associé au worker peut réaliser des tâches sans qu'il y ait d'interférence avec l'interface utilisateur. De plus, les web workers peuvent réaliser des opérations d'entrée/sortie grâce à XMLHttpRequest (bien que les attributs responseXML et channel soient nécessairement vides dans ces cas). Une fois créé, un worker peut envoyer des messages au code JavaScript qui l'a créé. De même, le script initial peut envoyer des messages au worker. Cette communication s'effectue grâce à des gestionnaires d'évènements. Dans cet article, nous verrons une introduction à l'utilisation des web workers.},
    language = {fr},
    urldate = {2026-05-02},
    journal = {MDN Web Docs},
    month = sep,
    year = {2025},
    author = {{MDN Web Docs}},
}
